{
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true
  },
  "chat.tools.terminal.autoApprove": {
    "/^-?\\d+\\.\\.-?\\d+$/": true,
    "/^cargo\\s+(?:build|build-all|check|clean|clippy|clippy-all|doc|fmt|fmt-check|run|test|test-all)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "ConvertFrom-Json": true,
    "ForEach-Object": true,
    "Get-Item": true,
    "Group-Object": true,
    "Out-Null": true,
    "Pop-Location": true,
    "Push-Location": true,
    "Test-Path": true,
    "git rev-parse": true,
    "i": true,
    "i++": true,
    "rustup": true,
    "type": true
  },
  "files.associations": {
    ".prettierignore": "ignore"
  },
  "json.schemaDownload.trustedDomains": {
    "https://models.dev/model-schema.json": true,
    "https://opencode.ai/config.json": true,
    "https://raw.githubusercontent.com/DavidAnson/markdownlint/main/schema/markdownlint-config-schema.json": true
  },
  "markdown.validate.enabled": true,
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "python-envs.pythonProjects": [],
  "rust-analyzer.check.allTargets": true,
  "rust-analyzer.check.command": "clippy"
}
