{
  "chat.tools.terminal.autoApprove": {
    "/^-?\\d+\\.\\.-?\\d+$/": true,
    "/^cargo\\s+(?:build|build-all|build-pkg|check|clean|clippy|clippy-all|clippy-pkg|doc|fmt|fmt-check|run|test|test-all|test-pkg)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "ConvertFrom-Json": true,
    "ConvertTo-Json": true,
    "ForEach-Object": true,
    "Get-Command": true,
    "Get-Item": true,
    "Get-Member": true,
    "git rev-parse": true,
    "Group-Object": true,
    "i": true,
    "i++": true,
    "Out-Null": true,
    "Pop-Location": true,
    "Push-Location": true,
    "rustfmt": true,
    "rustup": true,
    "Tee-Object": true,
    "Test-Path": true,
    "type": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.sortJSON": "explicit",
    "source.organizeImports": "explicit",
    "source.sort.json": "explicit"
  },
  "editor.formatOnSave": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "files.associations": {
    ".prettierignore": "ignore"
  },
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "json.schemaDownload.trustedDomains": {
    "https://models.dev/model-schema.json": true,
    "https://opencode.ai/config.json": true,
    "https://raw.githubusercontent.com/DavidAnson/markdownlint/main/schema/markdownlint-config-schema.json": true
  },
  "markdown.validate.enabled": true,
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "python-envs.pythonProjects": [],
  "rust-analyzer.check.allTargets": true,
  "rust-analyzer.check.command": "clippy"
}
